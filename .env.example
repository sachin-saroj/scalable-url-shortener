# ============================================
# Scalable URL Shortener — Environment Config
# ============================================
# Copy this file to .env and fill in values

# Application
APP_NAME=url-shortener
APP_ENV=development
APP_DEBUG=true
BASE_URL=http://localhost:8000
API_V1_PREFIX=/api/v1

# Database (PostgreSQL)
POSTGRES_USER=shortener
POSTGRES_PASSWORD=shortener_secret_2026
POSTGRES_DB=url_shortener
POSTGRES_HOST=db
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://${REDIS_HOST}:${REDIS_PORT}/0

# JWT Authentication
JWT_SECRET_KEY=change-this-to-a-very-long-random-string-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# Rate Limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_SECONDS=60

# Celery
CELERY_BROKER_URL=redis://${REDIS_HOST}:${REDIS_PORT}/1
CELERY_RESULT_BACKEND=redis://${REDIS_HOST}:${REDIS_PORT}/2

# URL Cache TTL (seconds)
URL_CACHE_TTL=86400

# Google Safe Browsing (optional)
GOOGLE_SAFE_BROWSING_API_KEY=

# Cors
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
